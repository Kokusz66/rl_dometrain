
@page "/pagedemo"
@page "/pagedemoagain"
@page "/pagedemo/{Variable}"
@page "/pagedemo/{IntVariable:int}"

<h3>PageDemo</h3>

<strong>String Value:</strong> @(Variable??"No string variable")
<br />
<strong>Int value:</strong> @(IntVariable==null?"No int variable":IntVariable)
<br />
<strong>First name:</strong> @(FirstName ?? "No first name supplied")

@code {
    [Parameter]
    public string? Variable { get; set; }
    [Parameter]
    public int? IntVariable { get; set; }

    [Parameter, SupplyParameterFromQuery]
    public string? FirstName { get; set; }


}
