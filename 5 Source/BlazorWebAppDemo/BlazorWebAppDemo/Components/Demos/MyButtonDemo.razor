@page "/MyButtonDemo"
@rendermode InteractiveServer

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<MyButton class="btn btn-primary" OnClick="IncrementCountAsync" ConfirmMessage="Do you really want to count up?">Click me</MyButton>

@code {
    private int currentCount = 0;

    private async Task IncrementCountAsync()
    {
        await Task.Delay(2000);
        currentCount++;
    }
}
